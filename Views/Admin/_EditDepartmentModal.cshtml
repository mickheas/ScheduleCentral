@model ScheduleCentral.Models.Department

<div class="modal-header border-bottom-0 pb-0">
    <div class="d-flex align-items-center">
        <div class="p-2 rounded-3 bg-primary-subtle me-3">
            <i class="bi bi-building-gear text-primary fs-4"></i>
        </div>
        <div>
            <h5 class="modal-title fw-bold text-dark">Edit Department</h5>
            <p class="text-muted small mb-0">Modify department metadata and leadership.</p>
        </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form asp-action="EditDepartment" method="post">
    <div class="modal-body p-4">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: 0.05em;"></label>
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-info-square text-muted"></i></span>
                <input asp-for="Name" class="form-control border-start-0 ps-0" required />
            </div>
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Code" class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: 0.05em;"></label>
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-hash text-muted"></i></span>
                <input asp-for="Code" class="form-control border-start-0 ps-0" required />
            </div>
            <span asp-validation-for="Code" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="HeadId" class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: 0.05em;">Department Head</label>
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-person-badge text-muted"></i></span>
                <select asp-for="HeadId" class="form-select border-start-0 ps-0" asp-items="ViewBag.PotentialHeads">
                    <option value="">-- Assign Leadership --</option>
                </select>
            </div>
        </div>
    </div>
    <div class="modal-footer border-top-0 pt-0">
        <button type="button" class="btn btn-light fw-semibold text-secondary px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-indigo shadow-sm px-4">Save Changes</button>
    </div>
</form>