<div class="modal fade" id="editOfferingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form id="editOfferingForm" asp-action="Edit" method="post" class="needs-validation" novalidate>
                <div class="modal-header border-bottom-0 pb-0">
                    <div class="d-flex align-items-center">
                        <div class="p-2 rounded-3 bg-indigo-subtle me-3">
                            <i class="bi bi-gear-wide-connected text-indigo fs-4"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold text-dark" id="editModalTitle">Edit Offering</h5>
                            <p class="text-muted small mb-0">Configuration Summary</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body p-4">
                    <input type="hidden" id="editOfferingId" name="Id" />

                    <div class="mb-4">
                        <label class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: 0.05em;">Academic Department</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-building text-muted"></i></span>
                            <input class="form-control bg-light border-start-0 ps-0 fw-medium" id="editDepartment" name="Department" readonly />
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: 0.05em;">Academic Year</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-calendar-event text-muted"></i></span>
                                <input class="form-control bg-light border-start-0 ps-0" id="editAcademicYear" name="AcademicYear" readonly />
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small text-uppercase text-muted" style="letter-spacing: 0.05em;">Semester</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-hash text-muted"></i></span>
                                <input class="form-control bg-light border-start-0 ps-0" id="editSemester" name="Semester" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <div class="alert border-0 rounded-3 d-flex align-items-center mb-0" style="background-color: #f1f5f9; border-left: 4px solid #64748b !important;">
                            <i class="bi bi-info-circle-fill text-secondary me-3 fs-5"></i>
                            <div class="small text-muted">
                                <strong class="text-dark">Note:</strong> Core attributes and status are locked. To modify curriculum or batches, use the <strong>Manage Offering</strong> portal.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light fw-semibold text-secondary px-4" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-indigo shadow-sm px-4">
                        <i class="bi bi-check2-circle me-1"></i> Save Metadata
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-indigo-subtle { background-color: #eef2ff; }
    .text-indigo { color: #6366f1; }
    .btn-indigo { background-color: #6366f1; color: white; border: none; font-weight: 600; }
    .btn-indigo:hover { background-color: #4f46e5; color: white; }
    
    /* Make readonly inputs look "locked" but readable */
    input[readonly] {
        cursor: not-allowed;
        color: #475569;
        border-color: #e2e8f0;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var editModal = document.getElementById('editOfferingModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var id = button.getAttribute('data-id');
                var dept = button.getAttribute('data-department');
                var ay = button.getAttribute('data-academicyear');
                var sem = button.getAttribute('data-semester');

                document.getElementById('editOfferingId').value = id;
                document.getElementById('editDepartment').value = dept;
                document.getElementById('editAcademicYear').value = ay;
                document.getElementById('editSemester').value = sem;
                document.getElementById('editModalTitle').textContent = 'Offering Info';
            });
        }
    });
</script>