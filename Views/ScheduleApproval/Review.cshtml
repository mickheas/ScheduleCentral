@model ScheduleCentral.Controllers.ScheduleApprovalReviewViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Review Schedule";

    var clrIndigo = "#4f46e5";
    var clrEmerald = "#10b981";
    var clrAmber = "#f59e0b";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
        <div>
            <h1 class="h4 mb-1 fw-bold" style="color: @clrIndigo;">Review Schedule</h1>
            <div class="text-muted small">Publication #@Model.PublicationId · @Model.AcademicYear · Sem @Model.Semester</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-outline-secondary fw-bold" asp-controller="ScheduleApproval" asp-action="Index">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border-top: 4px solid @clrIndigo;">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold" style="color:@clrIndigo;">Summary</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <div class="p-3 rounded-3 border bg-light">
                                <div class="text-muted small">Meetings</div>
                                <div class="fw-bold">@Model.MeetingsCount</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="p-3 rounded-3 border bg-light">
                                <div class="text-muted small">Sections</div>
                                <div class="fw-bold">@Model.SectionsCount</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="p-3 rounded-3 border bg-light">
                                <div class="text-muted small">Submitted (UTC)</div>
                                <div class="fw-bold">@(Model.SubmittedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                            </div>
                        </div>
                    </div>

                    @if (Model.Departments != null && Model.Departments.Any())
                    {
                        <div class="mt-4">
                            <div class="fw-bold small text-uppercase text-muted mb-2">Departments</div>
                            <div>
                                @foreach (var d in Model.Departments)
                                {
                                    <span class="badge rounded-pill px-3 py-2 me-2 mb-2" style="background-color:#ecfeff; color:#155e75; border:1px solid #cffafe;">@d</span>
                                }
                            </div>
                        </div>
                    }

                    @if (Model.SectionLinks != null && Model.SectionLinks.Any())
                    {
                        <div class="mt-4">
                            <div class="fw-bold small text-uppercase text-muted mb-2">Open a Section Grid</div>
                            <div class="list-group">
                                @foreach (var s in Model.SectionLinks)
                                {
                                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-controller="Schedule" asp-action="Grid" asp-route-sectionId="@s.SectionId" asp-route-publicationId="@Model.PublicationId" asp-route-returnUrl="@Url.Action("Review", "ScheduleApproval", new { id = Model.PublicationId })">
                                        <span class="small">
                                            @s.DisplayName
                                            @if (s.IsExtension)
                                            {
                                                <span class="badge rounded-pill ms-2" style="background-color:#fffbeb; color:@clrAmber; border: 1px solid #fef3c7;">Extension</span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill ms-2" style="background-color:#f0fdf4; color:@clrEmerald; border: 1px solid #dcfce7;">Regular</span>
                                            }
                                        </span>
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border-top: 4px solid @clrEmerald;">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold" style="color:@clrEmerald;">Decision</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-controller="ScheduleApproval" asp-action="Approve" method="post" class="mb-3" onsubmit="return confirm('Approve and publish this schedule?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.PublicationId" />
                        <button type="submit" class="btn btn-success fw-bold w-100">
                            <i class="bi bi-check2-circle me-2"></i> Approve & Publish
                        </button>
                    </form>

                    <div class="border-top pt-3">
                        <form asp-controller="ScheduleApproval" asp-action="Reject" method="post" onsubmit="return confirm('Reject this schedule? Feedback is required.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.PublicationId" />
                            <label class="form-label small fw-bold text-uppercase text-muted">Rejection Feedback</label>
                            <textarea name="feedback" class="form-control" rows="4" placeholder="Describe what needs to be fixed..."></textarea>
                            <button type="submit" class="btn fw-bold w-100 mt-2" style="background-color:@clrAmber; color:white;">
                                <i class="bi bi-x-circle me-2"></i> Reject
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
