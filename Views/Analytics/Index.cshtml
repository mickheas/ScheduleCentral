@using System.Text.Json
@model ScheduleCentral.Models.ViewModels.AnalyticsDashboardViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Analytics";

    // Base colors
    var clrIndigo = "#6366f1";
    var clrEmerald = "#10b981";
    var clrAmber = "#f59e0b";
    var clrCyan = "#06b6d4";
}

<style>
    /* Custom utility to make cards float nicely */
    .hover-float {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-float:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.08) !important;
    }
    .card-header-clean {
        background: transparent;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        padding-bottom: 0.5rem;
        margin-bottom: 0.5rem;
    }
</style>

<div class="container-fluid px-4 py-4">

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1 fw-bold" style="color:@clrIndigo;">Analytics Dashboard</h1>
            <div class="text-muted small">
                Term: <strong>@Model.AcademicYear</strong> · Sem <strong>@Model.Semester</strong>
                @if (!string.IsNullOrWhiteSpace(Model.ScopeDepartment))
                {
                    <span> · Scope: <strong>@Model.ScopeDepartment</strong></span>
                }
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#filterPanel" aria-expanded="true" aria-controls="filterPanel">
                <i class="bi bi-funnel me-1"></i> Filters
            </button>
        </div>
    </div>

    <div class="collapse show mb-4 visible" id="filterPanel">
        <div class="card border-0 shadow-sm rounded-4 bg-light">
            <div class="card-body p-3">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Year</label>
                        <select class="form-select form-select-sm" name="academicYear">
                            @if (Model.AcademicYears == null || Model.AcademicYears.Count == 0)
                            {
                                <option value="@Model.AcademicYear" selected>@Model.AcademicYear</option>
                            }
                            else
                            {
                                foreach (var y in Model.AcademicYears)
                                {
                                    <option value="@y" selected="@(string.Equals(Model.AcademicYear, y, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@y</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Semester</label>
                        <select class="form-select form-select-sm" name="semester">
                            @if (Model.Semesters == null || Model.Semesters.Count == 0)
                            {
                                <option value="@Model.Semester" selected>@Model.Semester</option>
                            }
                            else
                            {
                                foreach (var s in Model.Semesters)
                                {
                                    <option value="@s" selected="@(string.Equals(Model.Semester, s, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@s</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 d-flex justify-content-end gap-2">
                        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index", "Analytics")">Reset</a>
                        <button type="submit" class="btn btn-sm text-white" style="background-color:@clrIndigo;">Apply Filters</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 hover-float">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center mb-2">
                        <div class="rounded-circle p-2 me-2" style="background-color: rgba(79, 70, 229, 0.1);">
                            <i class="bi bi-building" style="color: @clrIndigo"></i>
                        </div>
                        <div class="small text-muted fw-bold">Utilization</div>
                    </div>
                    <div class="h3 fw-bold mb-0">@Model.RoomUtilizationPercent.ToString("0.0")%</div>
                    <div class="small text-muted">@Model.RoomsUsed Rooms</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 hover-float">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center mb-2">
                        <div class="rounded-circle p-2 me-2" style="background-color: rgba(16, 185, 129, 0.1);">
                            <i class="bi bi-lightning" style="color: @clrEmerald"></i>
                        </div>
                        <div class="small text-muted fw-bold">Efficiency</div>
                    </div>
                    <div class="h3 fw-bold mb-0">@Model.ChangesPerMeeting.ToString("0.00")</div>
                    <div class="small text-muted">Changes/Mtg</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 hover-float">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center mb-2">
                        <div class="rounded-circle p-2 me-2" style="background-color: rgba(245, 158, 11, 0.1);">
                            <i class="bi bi-x-circle" style="color: @clrAmber"></i>
                        </div>
                        <div class="small text-muted fw-bold">Rejections</div>
                    </div>
                    <div class="h3 fw-bold mb-0">@Model.RejectionRatePercent.ToString("0.0")%</div>
                    <div class="small text-muted">Rate</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 hover-float">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center mb-2">
                        <div class="rounded-circle p-2 me-2" style="background-color: rgba(6, 182, 212, 0.1);">
                            <i class="bi bi-calendar-check" style="color: @clrCyan"></i>
                        </div>
                        <div class="small text-muted fw-bold">Meetings</div>
                    </div>
                    <div class="h3 fw-bold mb-0">@Model.TotalMeetings</div>
                    <div class="small text-muted">Total</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-3">
                    <div class="card-header-clean d-flex justify-content-between">
                        <span class="fw-bold small text-uppercase text-muted">Offerings Status</span>
                    </div>
                    <div class="position-relative" style="height: 180px; width: 100%;">
                        <canvas id="offeringsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-3">
                    <div class="card-header-clean d-flex justify-content-between">
                        <span class="fw-bold small text-uppercase text-muted">Top Rooms</span>
                    </div>
                    <div class="position-relative" style="height: 180px; width: 100%;">
                        <canvas id="roomsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>


        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-3">
                    <div class="card-header-clean d-flex justify-content-between">
                        <span class="fw-bold small text-uppercase text-muted">Trend (14 Days)</span>
                    </div>
                    <div class="position-relative" style="height: 180px; width: 100%;">
                        <canvas id="changesChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-3">
                    <div class="card-header-clean d-flex justify-content-between">
                         @if (string.Equals(Model.PrimaryRole, "Instructor", StringComparison.OrdinalIgnoreCase))
                         {
                            <span class="fw-bold small text-uppercase text-muted">My Weekly Load</span>
                         }
                         else
                         {
                            <span class="fw-bold small text-uppercase text-muted">By Department</span>
                         }
                    </div>
                    <div class="position-relative" style="height: 180px; width: 100%;">
                         <canvas id="distributionChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data Setup
        const offeringsLabels = @Html.Raw(Model.OfferingsStatusLabelsJson);
        const offeringsData = @Html.Raw(Model.OfferingsStatusDataJson);
        const roomsLabels = @Html.Raw(Model.TopRoomsLabelsJson);
        const roomsData = @Html.Raw(Model.TopRoomsDataJson);
        const changesLabels = @Html.Raw(Model.ChangesOverTimeLabelsJson);
        const changesData = @Html.Raw(Model.ChangesOverTimeDataJson);
        const isInstructor = '@Model.PrimaryRole'.toLowerCase() === 'instructor';
        const distLabels = isInstructor ? @Html.Raw(Model.MeetingsByDayLabelsJson) : @Html.Raw(Model.MeetingsByDepartmentLabelsJson);
        const distData = isInstructor ? @Html.Raw(Model.MeetingsByDayDataJson) : @Html.Raw(Model.MeetingsByDepartmentDataJson);

        // Global Defaults for "Beautiful" Look
        Chart.defaults.font.family = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif';
        Chart.defaults.font.size = 11;
        Chart.defaults.color = '#64748b';
        Chart.defaults.plugins.tooltip.padding = 10;
        Chart.defaults.plugins.tooltip.cornerRadius = 8;
        Chart.defaults.plugins.tooltip.backgroundColor = 'rgba(15, 23, 42, 0.9)';

        // Helper to create gradients
        function getGradient(ctx, colorStart, colorEnd) {
            const gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, colorStart);
            gradient.addColorStop(1, colorEnd);
            return gradient;
        }

        // 1. Offerings Chart (Doughnut)
        const ctxOffer = document.getElementById('offeringsChart').getContext('2d');
        new Chart(ctxOffer, {
            type: 'doughnut',
            data: {
                labels: offeringsLabels,
                datasets: [{
                    data: offeringsData,
                    backgroundColor: [
                        '#10b981', '#f59e0b', '#06b6d4', '#6366f1'
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%', // Thinner ring
                plugins: {
                    legend: { position: 'right', labels: { boxWidth: 10, usePointStyle: true } }
                }
            }
        });

        // 2. Rooms Chart (Bar with Gradients)
        const ctxRooms = document.getElementById('roomsChart').getContext('2d');
        new Chart(ctxRooms, {
            type: 'bar',
            data: {
                labels: roomsLabels,
                datasets: [{
                    label: 'Slots',
                    data: roomsData,
                    backgroundColor: getGradient(ctxRooms, '#34d399', '#059669'), // Gradient Emerald
                    borderRadius: 4,
                    barPercentage: 0.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } }, // Clean look
                    y: { border: { display: false }, grid: { color: '#f1f5f9', borderDash: [5, 5] } }
                }
            }
        });

        // 3. Changes Chart (Line with fill)
        const ctxChanges = document.getElementById('changesChart').getContext('2d');
        
        // Create fill gradient
        const fillGrad = ctxChanges.createLinearGradient(0,0,0,200);
        fillGrad.addColorStop(0, 'rgba(6, 182, 212, 0.2)');
        fillGrad.addColorStop(1, 'rgba(6, 182, 212, 0.0)');

        new Chart(ctxChanges, {
            type: 'line',
            data: {
                labels: changesLabels,
                datasets: [{
                    label: 'Changes',
                    data: changesData,
                    borderColor: '#06b6d4',
                    backgroundColor: fillGrad,
                    fill: true,
                    tension: 0.4, // Smooth curve
                    pointRadius: 0,
                    pointHoverRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } },
                    y: { display: false } // Sparkline style
                }
            }
        });

        // 4. Distribution Chart (Bar)
        const ctxDist = document.getElementById('distributionChart').getContext('2d');
        new Chart(ctxDist, {
            type: 'bar',
            data: {
                labels: distLabels,
                datasets: [{
                    label: 'Slots',
                    data: distData,
                    backgroundColor: getGradient(ctxDist, '#fcd34d', '#d97706'), // Gradient Amber
                    borderRadius: 4,
                    barPercentage: 0.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { display: !isInstructor } }, // Hide x labels if it gets too crowded
                    y: { border: { display: false }, grid: { display: false } }
                }
            }
        });
    </script>
}