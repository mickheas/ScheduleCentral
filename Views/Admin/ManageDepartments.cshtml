                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<!-- Create Department Modal -->
<div class="modal fade" id="createDeptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Create New Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-4">Add a new academic unit and optionally assign a head.</p>
                
                <form asp-action="CreateDepartment" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Department Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. Computer Science" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Code</label>
                        <input type="text" name="Code" class="form-control" placeholder="e.g. CS" required />
                        <div class="form-text">Short abbreviation for course codes (e.g. CS-101).</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small text-uppercase text-muted">Department Head</label>
                        <select name="HeadId" class="form-select" asp-items="ViewBag.PotentialHeads">
                            <option value="">-- Select Faculty Member --</option>
                        </select>
                        <div class="form-text">Selected user will be granted 'Department' role access.</div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Create Department</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal placeholder used by loadActionModal() -->
<div class="modal fade" id="actionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" id="actionModalContent">
            <!-- Content loaded dynamically via AJAX -->
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Global function to load the modal content
                function loadActionModal(url) {
                    var modalPlaceholder = $('#actionModal');

                    // 1. Reset content to spinner
                    $('#actionModalContent').html(`
                        <div class="modal-body text-center p-5">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    `);

                    // 2. Show Modal
                    var myModal = new bootstrap.Modal(document.getElementById('actionModal'));
                    myModal.show();

                    // 3. Fetch Partial View
                    $.get(url).done(function (data) {
                        $('#actionModalContent').html(data);

                        // Re-enable validation for new form content
                        var form = $('#actionModalContent').find('form');
                        if (form.length > 0 && $.validator && $.validator.unobtrusive) {
                            $.validator.unobtrusive.parse(form);
                        }
                    }).fail(function() {
                        $('#actionModalContent').html('<div class="modal-body text-danger">Failed to load content.</div>');
                    });
                }

                // Global handler for AJAX form submission inside the modal
                $(document).on('submit', '#actionModal form', function (e) {
                    e.preventDefault();
                    var form = $(this);
                    var modalPlaceholder = $('#actionModal');

                    if (!form.valid()) return;

                    $.ajax({
                        url: form.attr('action'),
                        method: form.attr('method'),
                        data: form.serialize(),
                        success: function (response) {
                            if (response.success) {
                                // Close modal and reload page to see updates
                                var modalEl = document.getElementById('actionModal');
                                var modal = bootstrap.Modal.getInstance(modalEl);
                                modal.hide();
                                location.reload();
                            } else {
                                // If validation failed on server, replace content with response (containing errors)
                                $('#actionModalContent').html(response);

                                // Re-parse validation
                                var newForm = $('#actionModalContent').find('form');
                                if (newForm.length > 0 && $.validator) {
                                    $.validator.unobtrusive.parse(newForm);
                                }
                            }
                        },
                        error: function() {
                            alert('An unexpected error occurred.');
                        }
                    });
                });
    </script>
} *@
@model IEnumerable<ScheduleCentral.Models.Department>
@{
    ViewData["Title"] = "Manage Departments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --theme-indigo: #6366f1;
        --theme-cyan: #06b6d4;
        --theme-emerald: #10b981;
    }

    .table thead th {
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        background: #f8fafc !important;
        color: #64748b !important;
        border-bottom: 2px solid #e2e8f0;
    }

    .badge-code {
        background-color: #eef2ff;
        color: var(--theme-indigo);
        border: 1px solid #e0e7ff;
        font-weight: 700;
        padding: 0.5rem 0.8rem;
    }

    .avatar-dept {
        width: 38px;
        height: 38px;
        background-color: #ecfeff;
        color: var(--theme-cyan);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-action-sm {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-gray-800 fw-bold">Departments</h1>
        <p class="text-muted small mb-0">Manage academic units and assign leadership roles.</p>
    </div>

    <button type="button" class="btn btn-emerald shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#createDeptModal">
        <i class="bi bi-plus-circle-fill me-2"></i>Add Department
    </button>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 10%;">Code</th>
                        <th style="width: 30%;">Department Name</th>
                        <th style="width: 30%;">Department Head</th>
                        <th class="text-center">Stats</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="badge badge-code">@item.Code</span>
                            </td>
                            <td class="fw-bold text-dark">@item.Name</td>
                            <td>
                                @if (item.Head != null)
                                {
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-dept me-3">
                                            <i class="bi bi-person-badge fs-5"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-dark mb-0 small" style="line-height: 1.2;">@item.Head.FullName</div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@item.Head.Email</div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small italic"><i class="bi bi-dash-circle me-1"></i>Unassigned</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <span class="badge bg-light text-muted border fw-normal" title="Courses">
                                        <i class="bi bi-book me-1"></i>@item.Courses.Count
                                    </span>
                                    <span class="badge bg-light text-muted border fw-normal" title="Batches">
                                        <i class="bi bi-people me-1"></i>@item.Batches.Count
                                    </span>
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-outline-primary btn-action-sm" 
                                            onclick="loadActionModal('@Url.Action("GetEditDepartmentPartial", "Admin", new { id = item.Id })')"
                                            title="Edit Department">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    
                                    <button class="btn btn-outline-danger btn-action-sm" 
                                            onclick="loadActionModal('@Url.Action("GetDeleteDepartmentPartial", "Admin", new { id = item.Id })')"
                                            title="Delete Department">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-building text-muted display-6 d-block mb-3"></i>
                                <p class="text-muted">No departments found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createDeptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <div class="d-flex align-items-center">
                    <div class="p-2 rounded-3 bg-success-subtle me-3">
                        <i class="bi bi-building-add text-success fs-4"></i>
                    </div>
                    <div>
                        <h5 class="modal-title fw-bold text-dark">Create Department</h5>
                        <p class="text-muted small mb-0">Register a new academic unit.</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateDepartment" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Department Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. Computer Science" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Code / Abbreviation</label>
                        <input type="text" name="Code" class="form-control" placeholder="e.g. CS" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Department Head</label>
                        <select name="HeadId" class="form-select" asp-items="ViewBag.PotentialHeads">
                            <option value="">-- No Head Assigned --</option>
                        </select>
                    </div>

                    <div class="modal-footer border-top-0 px-0 pb-0 mt-2">
                        <button type="button" class="btn btn-light fw-semibold text-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-indigo shadow-sm px-4">Create Unit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="actionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" id="actionModalContent">
            </div>
    </div>
</div>

<style>
    .btn-emerald { background-color: var(--theme-emerald); color: white; border: none; font-weight: 600; }
    .btn-emerald:hover { background-color: #059669; color: white; }
    
    .btn-indigo { background-color: var(--theme-indigo); color: white; border: none; font-weight: 600; }
    .btn-indigo:hover { background-color: #4f46e5; color: white; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function loadActionModal(url) {
            $('#actionModalContent').html(`
                <div class="modal-body text-center p-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            `);
            
            var myModal = new bootstrap.Modal(document.getElementById('actionModal'));
            myModal.show();

            $.get(url).done(function (data) {
                $('#actionModalContent').html(data);
                var form = $('#actionModalContent').find('form');
                if (form.length > 0 && $.validator && $.validator.unobtrusive) {
                    $.validator.unobtrusive.parse(form);
                }
            }).fail(function() {
                $('#actionModalContent').html('<div class="modal-body text-danger p-5">Error loading content.</div>');
            });
        }

        $(document).on('submit', '#actionModal form', function (e) {
            e.preventDefault();
            var form = $(this);
            if (form.data('validator') && !form.valid()) return;

            $.ajax({
                url: form.attr('action'),
                method: form.attr('method'),
                data: form.serialize(),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        $('#actionModalContent').html(res);
                        $.validator.unobtrusive.parse($('#actionModalContent form'));
                    }
                }
            });
        });
    </script>
}