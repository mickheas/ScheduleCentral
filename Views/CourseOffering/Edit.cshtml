    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Course Allocations</h5>
