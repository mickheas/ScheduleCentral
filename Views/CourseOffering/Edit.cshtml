                                                    <tr>
                                                        <td>
                                                            @Html.DropDownListFor(m => m.Sections[i].RoomRequirements[j].RoomTypeId, Model.RoomTypeSelectList, "-- Type --", new { @class = "form-select form-select-sm" })
                                                            @Html.HiddenFor(m => m.Sections[i].RoomRequirements[j].Id)
                                                        </td>
                                                        <td>
                                                            @Html.TextBoxFor(m => m.Sections[i].RoomRequirements[j].HoursPerWeek, new { @class = "form-control form-control-sm", type = "number", min = "1" })
                                                        </td>
                                                        <td>
                                                            <button type="button" class="btn btn-sm btn-danger remove-room-req">Remove</button>
