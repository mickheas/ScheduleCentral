@* @model ScheduleCentral.Models.ViewModels.CourseOfferingIndexViewModel

@{
    ViewData["Title"] = "Course Offerings";
    //var offeringCards = ViewBag.OfferingCards as List<ScheduleCentral.Controllers.CourseOfferingIndexCardViewModel>;
