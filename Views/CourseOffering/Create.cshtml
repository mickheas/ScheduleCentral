@model ScheduleCentral.Models.ViewModels.CourseOfferingCreateViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create Course Offering";
}
<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">Create Course Offering</h5>
                <small class="text-muted">Create the academic container � Year + Semester + Department</small>
            </div>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Back</a>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Department</label>
                    <input asp-for="Department" class="form-control" readonly="@(!User.IsInRole("Admin"))" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Academic Year</label>
                    <input asp-for="AcademicYear" class="form-control" readonly />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Semester</label>
                    <input class="form-control" value="@Model.Semester" readonly />
                    <input type="hidden" asp-for="Semester" />
                </div>

                <div class="col-12 text-end mt-2">
                    <button type="submit" class="btn btn-primary">Create Offering</button>
                </div>
            </form>
        </div>
    </div>
</div>

@*
