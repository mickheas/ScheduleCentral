@model ScheduleCentral.Models.ViewModels.ScheduleAuditViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Schedule Audit";

    var clrIndigo = "#4f46e5";
    var clrEmerald = "#10b981";
    var clrCyan = "#06b6d4";
    var clrAmber = "#f59e0b";

    var totalPages = (int)Math.Ceiling((double)Math.Max(0, Model.TotalCount) / Math.Max(1, Model.PageSize));
    if (totalPages < 1) totalPages = 1;
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1 fw-bold" style="color:@clrIndigo;">Schedule Audit</h1>
            <div class="text-muted small">Timeline of schedule edits (from change logs) for approved/rejected publications.</div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4" style="border-top: 4px solid @clrAmber !important;">
        <div class="card-body p-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small text-muted">Academic Year</label>
                    <select class="form-select" name="academicYear">
                        @if (Model.AcademicYears == null || Model.AcademicYears.Count == 0)
                        {
                            <option value="@Model.AcademicYear" selected>@Model.AcademicYear</option>
                        }
                        else
                        {
                            @foreach (var y in Model.AcademicYears)
                            {
                                <option value="@y" selected="@(string.Equals(Model.AcademicYear, y, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@y</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small text-muted">Semester</label>
                    <select class="form-select" name="semester">
                        @if (Model.Semesters == null || Model.Semesters.Count == 0)
                        {
                            <option value="@Model.Semester" selected>@Model.Semester</option>
                        }
                        else
                        {
                            @foreach (var s in Model.Semesters)
                            {
                                <option value="@s" selected="@(string.Equals(Model.Semester, s, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@s</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small text-muted">Publication</label>
                    <select class="form-select" name="publicationId">
                        <option value="">All</option>
                        @if (Model.Publications != null)
                        {
                            @foreach (var p in Model.Publications)
                            {
                                <option value="@p.Id" selected="@(Model.PublicationId.HasValue && Model.PublicationId.Value == p.Id ? "selected" : null)">@p.Label</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small text-muted">Changed By</label>
                    <select class="form-select" name="changedByUserId">
                        <option value="">All</option>
                        @if (Model.Users != null)
                        {
                            @foreach (var u in Model.Users)
                            {
                                <option value="@u.Id" selected="@(string.Equals(Model.ChangedByUserId, u.Id, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@u.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small text-muted">Change Type</label>
                    <select class="form-select" name="changeType">
                        <option value="">All</option>
                        @if (Model.ChangeTypes != null)
                        {
                            @foreach (var t in Model.ChangeTypes)
                            {
                                <option value="@t" selected="@(string.Equals(Model.ChangeType, t, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@t</option>
                            }
                        }
                    </select>
                </div>

                <input type="hidden" name="page" value="1" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />

                <div class="col-12 d-flex justify-content-end gap-2">
                    <a class="btn btn-outline-secondary" href="@Url.Action("Audit", "Schedule")">Reset</a>
                    <button type="submit" class="btn text-white fw-bold" style="background-color:@clrIndigo;">Apply Filters</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border-top: 4px solid @clrIndigo !important;">
        <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
            <div>
                <span class="fw-bold">Timeline</span>
                <span class="text-muted small ms-2">@Model.TotalCount total</span>
            </div>
            <div class="text-muted small">Page @Model.Page of @totalPages</div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>When</th>
                        <th>User</th>
                        <th>Type</th>
                        <th>Old</th>
                        <th>New</th>
                        <th>Context</th>
                        <th style="width: 120px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Logs == null || Model.Logs.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No audit records found for the selected filters.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var l in Model.Logs)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@l.ChangedAtLocal</div>
                                    <div class="text-muted small">UTC: @l.ChangedAtUtc.ToString("u")</div>
                                </td>
                                <td>@l.ChangedBy</td>
                                <td>
                                    <span class="badge rounded-pill" style="background-color:@(string.IsNullOrWhiteSpace(l.ChangeType) ? "#e5e7eb" : clrCyan); color:@(string.IsNullOrWhiteSpace(l.ChangeType) ? "#374151" : "#ffffff");">
                                        @(string.IsNullOrWhiteSpace(l.ChangeType) ? "(unknown)" : l.ChangeType)
                                    </span>
                                </td>
                                <td>@l.OldLabel</td>
                                <td>@l.NewLabel</td>
                                <td>
                                    <div class="small">
                                        <div><strong>Dept:</strong> @l.Department</div>
                                        <div><strong>Section:</strong> @l.Section</div>
                                        <div><strong>Course:</strong> @l.Course</div>
                                        <div><strong>Room:</strong> @l.Room</div>
                                        <div><strong>Instructor:</strong> @l.Instructor</div>
                                    </div>
                                </td>
                                <td class="text-end">
                                    @if (l.SectionId.HasValue)
                                    {
                                        <a class="btn btn-sm btn-outline-primary" asp-controller="Schedule" asp-action="Grid" asp-route-sectionId="@l.SectionId" asp-route-publicationId="@l.PublicationId" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString">View</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="text-muted small">
                Showing @Model.PageSize per page.
            </div>
            <div class="d-flex gap-2">
                @{
                    var prev = Math.Max(1, Model.Page - 1);
                    var next = Math.Min(totalPages, Model.Page + 1);
                }
                <a class="btn btn-sm btn-outline-secondary @(Model.Page <= 1 ? "disabled" : "")" href="@Url.Action("Audit", "Schedule", new { academicYear = Model.AcademicYear, semester = Model.Semester, publicationId = Model.PublicationId, changedByUserId = Model.ChangedByUserId, changeType = Model.ChangeType, page = prev, pageSize = Model.PageSize })">Prev</a>
                <a class="btn btn-sm btn-outline-secondary @(Model.Page >= totalPages ? "disabled" : "")" href="@Url.Action("Audit", "Schedule", new { academicYear = Model.AcademicYear, semester = Model.Semester, publicationId = Model.PublicationId, changedByUserId = Model.ChangedByUserId, changeType = Model.ChangeType, page = next, pageSize = Model.PageSize })">Next</a>
            </div>
        </div>
    </div>
</div>
