@model ScheduleCentral.Models.Course
@{
    ViewData["Title"] = "Edit Course";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h2 class="h4 mb-4 fw-bold">Edit Course <small class="text-muted fw-normal">— @ViewBag.DepartmentName</small></h2>

            <form asp-action="Edit" method="post" class="card shadow-sm border-0">
                <input type="hidden" asp-for="Id" />
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Course Code</label>
                            <input asp-for="Code" class="form-control form-control-lg bg-light border-0 shadow-none fw-bold text-primary" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Credit Units</label>
                            <input asp-for="CreditHours" type="number" class="form-control form-control-lg bg-light border-0 shadow-none" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium">Course Name</label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-none" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Contact Hours</label>
                            <input asp-for="LectureHours" type="number" class="form-control bg-light border-0 shadow-none" />
                            <input asp-for="LabHours" type="hidden" value="0" />
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white p-3 d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-link text-muted text-decoration-none">Cancel Changes</a>
                    <button type="submit" class="btn btn-primary px-5 shadow-sm">Update Course</button>
                </div>
            </form>
        </div>
    </div>
</div>