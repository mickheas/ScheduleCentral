@model IEnumerable<ScheduleCentral.Models.YearLevel>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Manage Year Levels";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">Year Levels</h4>
            <small class="text-muted">Create and manage year levels and batches for your department</small>
        </div>
        <div>
            <a asp-action="CreateYearLevel" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add Year Level</a>
        </div>
    </div>

    <div class="row g-3">
        @foreach (var y in Model)
        {
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">@y.Name @Html.Raw(" <small class='text-muted'>Year</small>")</h6>
                            <p class="small text-muted mb-0">@y.Batches.Count() batch(es)</p>
                        </div>
                        <div class="btn-group">
                            <a asp-action="AddBatch" asp-route-yearLevelId="@y.Id" class="btn btn-sm btn-outline-primary">Add Batch</a>
                            <a asp-action="ManageBatch" asp-route-batchId="@(y.Batches.FirstOrDefault()?.Id ?? 0)" class="btn btn-sm btn-primary">Manage</a>
                        </div>
                    </div>
                    @if (y.Batches != null && y.Batches.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var b in y.Batches)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@b.Name</strong>
                                        <div class="small text-muted">Semester @b.Semester</div>
                                    </div>
                                    <div>
                                        <a asp-action="ManageBatch" asp-route-batchId="@b.Id" class="btn btn-sm btn-outline-secondary">Open</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

