@using Microsoft.AspNetCore.Identity
@using ScheduleCentral.Models
@using ScheduleCentral.Services
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NotificationService NotificationService

@{
    var hideNav = ViewData["HideNav"] as bool? ?? false;
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var user = isAuthenticated ? await UserManager.GetUserAsync(User!) : null;
    var userName = user?.FirstName ?? User?.Identity?.Name;
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var unreadNotifications = isAuthenticated && user != null ? await NotificationService.GetUnreadCountAsync(user.Id) : 0;
    var recentNotifications = isAuthenticated && user != null ? await NotificationService.GetRecentAsync(user.Id, 8) : new List<UserNotification>();

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string Active(string controller, string? action = null)
    {
        if (!string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)) return "";
        if (action != null && !string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)) return "";
        return "active";
    }
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<!-- Initial theme set here, managed by JS -->
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Class Schedule Management </title>

    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Tailwind CSS (CDN utilities) -->
    <script>
        tailwind = { config: { corePlugins: { preflight: false } } };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Material Icons for Material Tailwind components -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ScheduleCentral.styles.css" asp-append-version="true" />

    <style>

        :root {
                --sc-primary: #4f46e5;
                --sc-primary-soft: #eef2ff;
                --sc-bg: #f4f5fb;
                --sc-surface: #ffffff;
                --sc-border-subtle: #e5e7eb;
                --sc-text-main: #111827;
                --sc-text-muted: #6b7280;
        }

        /* --- LIGHT MODE BASE STYLES --- */

                body {
                        padding-top: 56px; /* Height of navbar */
                        background-color: var(--sc-bg); /* Light background */
                        color: var(--sc-text-main); /* Dark text */
                        transition: background-color 0.3s, color 0.3s; /* Smooth theme transition */
                        min-height: 100vh;
                        display: flex;
                        flex-direction: column;
                }

        .navbar {
                background-color: var(--sc-surface) !important;
                border-bottom: 1px solid var(--sc-border-subtle);
                box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
        }

        .navbar .navbar-brand {
                font-weight: 700;
                letter-spacing: 0.08em;
        }

        .navbar .nav-link {
                color: var(--sc-text-muted);
        }

        .navbar .nav-link:hover {
                color: var(--sc-primary);
        }

        /* Sidebar Styles */
                #sidebar {
                        width: 60px;
                        transition: width 0.3s, background-color 0.3s, box-shadow 0.3s;
                        z-index: 1000;
                        background-color: var(--sc-surface); /* Light Sidebar */
                        box-shadow: 1px 0 0 var(--sc-border-subtle);
                }

        /* Sidebar Links (Light Mode) */
                #sidebar .nav-link {
                        white-space: nowrap;
                        padding: 0.75rem 1rem;
                        color: var(--sc-text-muted);
                        border-left: 3px solid transparent;
                        border-radius: 0.375rem;
                        margin: 0.125rem 0.5rem;
                }

                #sidebar .nav-link:hover {
                        background-color: var(--sc-primary-soft);
                        color: var(--sc-primary);
                }

                #sidebar .nav-link.active {
                        background-color: var(--sc-primary-soft);
                        color: var(--sc-primary);
                        border-left-color: var(--sc-primary);
                }

                .nav-item-header {
                        color: var(--sc-text-muted) !important; /* Muted text */
                }

                footer {
                        background-color: var(--sc-surface) !important; /* Ensure footer uses light background */
                        color: var(--sc-text-muted);
                }

        /* --- DARK MODE OVERRIDES --- */
                html[data-bs-theme="dark"] body {
                        background-color: #1a1e22; /* Darker main background */
                        color: #f8f9fa; /* Light text */

        }

                html[data-bs-theme="dark"] #sidebar {
                        background-color: #212529; /* Dark Sidebar background */
                        border-color: #343a40 !important;
                        box-shadow: 1px 0 5px rgba(255, 255, 255, 0.05);

        }


        /* Sidebar Links (Dark Mode) */
                html[data-bs-theme="dark"] #sidebar .nav-link {
                        color: #adb5bd; /* Light gray text */
                        border-left-color: transparent;

        }

                html[data-bs-theme="dark"] #sidebar .nav-link:hover {
                        background-color: #343a40; /* Dark hover */
                        color: #9ec5fe; /* Lighter primary blue */

        }

                html[data-bs-theme="dark"] #sidebar .nav-link.active {
                        background-color: #3f444a; /* Dark active background */
                        color: #9ec5fe;
                        border-left-color: #9ec5fe;

        }





                html[data-bs-theme="dark"] .nav-item-header {
                        color: #adb5bd !important; /* Lighter muted text */

        }






        /* Navbar overrides */
                html[data-bs-theme="dark"] .navbar {
                        background-color: #212529 !important; /* Dark Navbar background */
                        border-color: #343a40 !important;

        }

                html[data-bs-theme="dark"] .navbar .text-dark,
                html[data-bs-theme="dark"] .navbar .nav-link {
                        color: #f8f9fa !important; /* Ensures icons and links are light */

        }






        /* Footer overrides */
                html[data-bs-theme="dark"] footer {
                        background-color: #212529 !important; /* Dark Footer */
                        border-color: #343a40 !important;
                        color: #adb5bd;

        }

                html[data-bs-theme="dark"] footer a {
                        color: #adb5bd;

        }






        /* Ensure the text-danger logout button remains visible in dark mode */
                html[data-bs-theme="dark"] #sidebar button.text-danger {
                        color: #dc3545 !important;

        }






        /* General layout styles (preserved) */
                #sidebar.expanded {
                        width: 240px;

        }


        /* Hide text when collapsed */
                #sidebar .sidebar-text {
                        display: none;
                        opacity: 0;
                        transition: opacity 0.2s;

        }


        /* Show text when expanded */
                #sidebar.expanded .sidebar-text {
                        display: inline;
                        opacity: 1;
                        margin-left: 10px;

        }


        /* Icons are always centered/visible */
                #sidebar .nav-link i {
                        font-size: 1.2rem;
                        min-width: 24px;
                        text-align: center;

        }


        /* Content Area Adjustment */
                #content {
                        margin-left: 60px;
                        transition: margin-left 0.3s;
                        width: 100%;
                        padding-bottom: 80px;

        }

                #sidebar.expanded ~ #content {
                        margin-left: 240px;
                        width: calc(100% - 240px);

        }


        /* Ensure main layout takes remaining height so footer sticks to bottom */
                body > .d-flex {
                        flex: 1 0 auto;

        }


        /* Custom accordion visibility classes to avoid Bootstrap/Material conflicts */
                .sc-accordion-panel {
                        display: none;

        }

                .sc-accordion-panel.sc-open {
                        display: block;

        }


        /* Headers in sidebar */
                .nav-item-header {
                        font-size: 0.75rem;
                        text-transform: uppercase;
                        letter-spacing: 0.05em;
                        padding: 1rem 1rem 0.5rem;
                        display: none; /* Hidden when collapsed */

        }





                #sidebar.expanded .nav-item-header {
                        display: block;

        }





                footer.footer {
                        position: relative !important;
                        bottom: auto !important;
                        width: 100%; 
                        line-height: 40px;
                        margin-left: 60px;
                        transition: margin-left 0.3s;
                        flex-shrink: 0;

        }


                #sidebar.expanded ~ footer {
                        margin-left: 240px;

        }

        /* Utility to hide scrollbars but allow scrolling */
        .no-scrollbar {
            -ms-overflow-style: none;  /* IE and Edge */
            scrollbar-width: none;  /* Firefox */
            overflow-x: hidden !important; /* Force hide horizontal scrollbar */
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none; /* Chrome, Safari and Opera */
        }

        /* Sidebar Divider Styling */
        .sidebar-divider {
            margin: 8px 16px;
            border-top: 1px solid var(--sc-border-subtle);
        }

        html[data-bs-theme="dark"] .sidebar-divider {
            border-top-color: rgba(255, 255, 255, 0.1);
        }

    </style>
</head>
