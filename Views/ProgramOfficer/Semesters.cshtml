@model IEnumerable<ScheduleCentral.Models.AcademicPeriod>
@{
    ViewData["Title"] = "Manage Semesters";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Palette Colors
    var clrIndigo = "#4f46e5";
    var clrEmerald = "#10b981";
    var clrSlate = "#64748b";
    var lightBg = "#f8fafc";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 mb-1 fw-bold" style="color: @clrIndigo;">Academic Periods</h1>
            <p class="text-muted small">Manage semesters and define the active window for department submissions.</p>
        </div>
        <button class="btn text-white fw-bold px-4 shadow-sm" 
                style="background-color: @clrIndigo; border-radius: 10px;"
                data-bs-toggle="modal" data-bs-target="#createSemesterModal">
            <i class="bi bi-plus-lg me-2"></i> New Semester
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: @lightBg;">
                    <tr class="small text-uppercase text-muted fw-bold">
                        <th class="ps-4 py-3">Semester Name</th>
                        <th>Duration</th>
                        <th>Timeline Status</th>
                        <th class="text-end pe-4">Management</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="@(item.IsActive ? $"background-color: #f5f3ff; border-left: 4px solid {clrIndigo};" : "")">
                            <td class="ps-4">
                                <div class="fw-bold @(item.IsActive ? "text-primary" : "text-dark")">@item.Name</div>
                                @if(item.IsActive){ <small class="text-primary fw-medium" style="font-size: 0.7rem;">CURRENTLY ACTIVE</small> }
                            </td>
                            <td>
                                <div class="small d-flex align-items-center gap-2">
                                    <span class="text-muted">@item.StartDate.ToString("MMM dd, yyyy")</span>
                                    <i class="bi bi-arrow-right text-muted opacity-50"></i>
                                    <span class="text-muted">@item.EndDate.ToString("MMM dd, yyyy")</span>
                                </div>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge rounded-pill px-3 py-2" 
                                          style="background-color: #dcfce7; color: @clrEmerald; border: 1px solid #bbf7d0;">
                                        <i class="bi bi-check-circle-fill me-1"></i> Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill px-3 py-2" 
                                          style="background-color: #f1f5f9; color: @clrSlate; border: 1px solid #e2e8f0;">
                                        <i class="bi bi-lock-fill me-1"></i> Closed
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (!item.IsActive)
                                {
                                    <form asp-action="SetActiveSemester" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary px-3 fw-bold" 
                                                style="border-radius: 8px;"
                                                onclick="return confirm('Activating this semester will close any currently active ones. Continue?');">
                                            Make Active
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small italic">System Default</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createSemesterModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold" style="color: @clrIndigo;">Create New Semester</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateSemester" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Semester Name</label>
                        <input name="Name" class="form-control border-0 shadow-sm py-2" 
                               style="background-color: @lightBg;" 
                               placeholder="e.g. 2025/26 Sem I" required />
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col">
                            <label class="form-label small fw-bold text-muted">Start Date</label>
                            <input name="StartDate" type="date" class="form-control border-0 shadow-sm" 
                                   style="background-color: @lightBg;" required />
                        </div>
                        <div class="col">
                            <label class="form-label small fw-bold text-muted">End Date</label>
                            <input name="EndDate" type="date" class="form-control border-0 shadow-sm" 
                                   style="background-color: @lightBg;" required />
                        </div>
                    </div>
                    <div class="p-3 rounded-3 d-flex align-items-center justify-content-between" style="background-color: #f5f3ff;">
                        <div>
                            <label class="form-check-label fw-bold small" for="isActiveCheck" style="color: @clrIndigo;">Set as Active</label>
                            <div class="text-muted" style="font-size: 0.7rem;">Departments can start submitting for this term immediately.</div>
                        </div>
                        <div class="form-check form-switch m-0">
                            <input name="IsActive" value="true" class="form-check-input" type="checkbox" id="isActiveCheck" checked>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn text-white fw-bold px-4 shadow-sm" style="background-color: @clrIndigo; border-radius: 8px;">
                        Create Semester
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>