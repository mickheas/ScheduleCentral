@model List<ScheduleCentral.Models.ViewModels.BatchCourseViewModel>

<table class="table table-hover align-middle mb-0">
    <thead class="table-light">
        <tr>
            <th>Course</th>
            <th>Instructor</th>
            <th>Room Types</th>
            <th>Contact Hrs</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center py-4 text-muted">No courses added to this batch yet.</td>
            </tr>
        }
        else
        {
            foreach (var c in Model)
            {
                <tr>
                    <td class="fw-semibold">@c.CourseName</td>
                    <td>@c.InstructorName</td>
                    <td>
                        @if (c.RoomTypes?.Any() ?? false)
                        {
                            foreach (var rt in c.RoomTypes)
                            {
                                <span class="badge bg-secondary me-1">@rt</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small">No requirement</span>
                        }
                    </td>
                    <td>@c.ContactHours</td>
                    <td>
                        <span class="badge @(c.Status == "Draft" ? "bg-info text-dark" : "bg-success")">@c.Status</span>
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary me-1" href="@Url.Action("Edit", new { id = c.Id })"><i class="bi bi-pencil"></i></a>
                        <a class="btn btn-sm btn-outline-danger" href="@Url.Action("Delete", new { id = c.Id })"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

