@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h4 class="text-center fw-bold mb-2 text-secondary">My Profile</h4>
<p class="text-center text-muted small mb-4">Update your account details.</p>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="profile-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
    
    <!-- Username (Read Only) -->
    <div class="form-floating mb-3">
        <input asp-for="Username" class="form-control bg-light" placeholder="Username" disabled />
        <label asp-for="Username" class="form-label">Username</label>
    </div>

    <!-- Phone Number -->
    <div class="form-floating mb-4">
        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Phone Number" />
        <label asp-for="Input.PhoneNumber" class="form-label">Phone Number</label>
        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
    </div>
    
    <!-- Save Button -->
    <div class="d-grid gap-2 mb-3">
        <button id="update-profile-button" type="submit" class="btn btn-gradient-primary btn-lg fw-bold fs-6">Save Changes</button>
    </div>
    
    <!-- Navigation Links (Since we hid the sidebar in this layout context) -->
    <div class="d-flex justify-content-between border-top pt-3 mt-3">
        <a asp-page="./ChangePassword" class="text-decoration-none small fw-bold text-secondary">
            <i class="bi bi-key"></i> Change Password
        </a>
        <a asp-page="./Email" class="text-decoration-none small fw-bold text-secondary">
            <i class="bi bi-envelope"></i> Update Email
        </a>
    </div>
    
    <div class="text-center mt-3">
        <a href="/" class="text-decoration-none small text-muted">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}