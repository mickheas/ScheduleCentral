@model ScheduleCentral.Models.ViewModels.AdminCreateUserViewModel

<div class="modal-header border-bottom-0 pb-0">
    <div class="d-flex align-items-center">
        <div class="p-2 rounded-3 bg-success-subtle me-3">
            <i class="bi bi-person-fill-add text-success fs-4"></i>
        </div>
        <div>
            <h5 class="modal-title fw-bold text-dark">Provision User</h5>
            <p class="text-muted small mb-0">Create a new system identity and assign access.</p>
        </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body p-4">
    <form asp-action="CreateUser" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6 mb-3">
                <label asp-for="FirstName" class="form-label fw-semibold small text-uppercase" style="letter-spacing: 0.05em; color: #64748b;"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-muted"></i></span>
                    <input asp-for="FirstName" class="form-control border-start-0 ps-0" placeholder="e.g. John" />
                </div>
                <span asp-validation-for="FirstName" class="text-danger x-small"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="LastName" class="form-label fw-semibold small text-uppercase" style="letter-spacing: 0.05em; color: #64748b;"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-muted"></i></span>
                    <input asp-for="LastName" class="form-control border-start-0 ps-0" placeholder="e.g. Doe" />
                </div>
                <span asp-validation-for="LastName" class="text-danger x-small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label fw-semibold small text-uppercase" style="letter-spacing: 0.05em; color: #64748b;"></label>
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="name@company.com" />
            </div>
            <span asp-validation-for="Email" class="text-danger x-small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label fw-semibold small text-uppercase" style="letter-spacing: 0.05em; color: #64748b;"></label>
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
            </div>
            <span asp-validation-for="Password" class="text-danger x-small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="SelectedRoles" class="form-label fw-semibold small text-uppercase" style="letter-spacing: 0.05em; color: #64748b;">Access Permissions</label>
            <div class="border rounded-3 p-3" style="background-color: #f8fafc; border-style: dashed !important;">
                <div class="row g-2">
                    @{ var roleIndex = 0; }
                    @foreach (var role in (IEnumerable<SelectListItem>)ViewBag.Roles)
                    {
                        var roleKey = (role.Value ?? role.Text ?? "").Trim();
                        var safe = new string(roleKey.Where(char.IsLetterOrDigit).ToArray());
                        if (string.IsNullOrWhiteSpace(safe)) safe = $"idx{roleIndex}";
                        var rid = $"createRole_{safe}_{roleIndex}";
                        <div class="col-6">
                            <div class="form-check custom-checkbox">
                                <input class="form-check-input" type="checkbox" id="@rid" name="SelectedRoles" value="@role.Value" @(role.Selected ? "checked" : null) />
                                <label class="form-check-label fw-medium text-dark" for="@rid" style="font-size: 0.85rem;">@role.Text</label>
                            </div>
                        </div>
                        roleIndex++;
                    }
                </div>
            </div>
            <span asp-validation-for="SelectedRoles" class="text-danger x-small"></span>
        </div>

        <div class="modal-footer border-top-0 px-0 pb-0 gap-2">
            <button type="button" class="btn btn-light fw-semibold text-secondary px-4" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-indigo shadow-sm px-4">
                <i class="bi bi-check2-circle me-1"></i> Create Identity
            </button>
        </div>
    </form>
</div>

<style>
    /* Specific tweaks for this elite modal */
    .x-small { font-size: 0.75rem; }
    
    .input-group-text {
        border-color: #e2e8f0;
    }
    
    .form-control:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    .btn-indigo { 
        background-color: #6366f1; 
        color: white; 
        border: none; 
        transition: all 0.2s;
    }
    .btn-indigo:hover { 
        background-color: #4f46e5; 
        color: white; 
        transform: translateY(-1px);
    }

    /* Modern Checkbox color */
    .form-check-input:checked {
        background-color: #06b6d4; /* Cyan */
        border-color: #06b6d4;
    }
</style>