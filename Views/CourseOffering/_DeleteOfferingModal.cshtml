<div class="modal fade" id="deleteOfferingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form id="deleteOfferingForm" asp-action="DeleteConfirmed" method="post">
                <div class="modal-body p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-circle mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                    </div>

                    <h4 class="fw-bold text-dark mb-2">Delete Offering?</h4>
                    <p class="text-muted px-3">
                        You are about to permanently remove this course offering. 
                        <span class="text-danger fw-semibold">All linked batches and course rows will be lost.</span>
                    </p>

                    <input type="hidden" id="deleteOfferingId" name="Id" />

                    <div class="alert border-0 rounded-3 text-start mt-4 mb-0" style="background-color: #fff1f2;">
                        <div class="d-flex">
                            <i class="bi bi-info-circle-fill text-danger me-3 fs-5"></i>
                            <div>
                                <strong class="text-danger-emphasis d-block mb-1">Finality Warning</strong>
                                <span class="small text-danger" style="opacity: 0.85;">
                                    This action is immediate and cannot be undone. System logs will record this deletion.
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-top-0 pt-0 pb-4 justify-content-center">
                    <button type="button" class="btn btn-light fw-semibold text-secondary px-4 me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger shadow-sm px-4 fw-bold">
                        <i class="bi bi-trash3 me-1"></i> Confirm Deletion
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Styling for the soft red background */
    .bg-danger-subtle {
        background-color: #ffe4e6 !important;
    }
    
    /* Ensuring the modal doesn't look too wide for a simple confirmation */
    #deleteOfferingModal .modal-dialog {
        max-width: 400px;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var deleteModal = document.getElementById('deleteOfferingModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var id = button.getAttribute('data-id');
                document.getElementById('deleteOfferingId').value = id;
            });
        }
    });
</script>