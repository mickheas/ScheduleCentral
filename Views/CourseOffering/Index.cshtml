                                item.Status == OfferingStatus.Rejected ? "bg-danger" : "bg-secondary text-white")">
                                @item.Status
                            </span>
                        </div>

                        
                        @if (item.Status == OfferingStatus.Creation || item.Status == OfferingStatus.Draft)
                        {
                            <div class="mt-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <small class="text-muted fw-semibold">Completion Progress</small>
                                    <small class="text-muted fw-bold">@item.ProgressPercentage%</small>
