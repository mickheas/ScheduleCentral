@model List<ScheduleCentral.Models.Batch>
@{
    // This view displays all available course offerings (batches) for management.
    ViewData["Title"] = "Academic Offering Batches";
}

<div class="container py-5">
    <h2 class="display-6 mb-4 text-primary border-bottom pb-2">Select Offering to Manage</h2>
    <p class="lead text-muted">
        Choose an academic batch to view and assign courses, instructors, and room slots.
        
    </p>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center mt-5 shadow-sm" role="alert">
            <h4 class="alert-heading">No Offerings Found</h4>
            <p>There are no current academic batches available for assignment management.</p>
            <hr>
            <p class="mb-0">Please create a new Course Offering first.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-4">
            @foreach (var batch in Model)
            {
                <div class="col">
                    <div class="card shadow-lg h-100 border-0 rounded-3 hover:shadow-xl transition duration-300">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark">@batch.Name</h5>
                            <h6 class="card-subtitle mb-3 text-muted">Department: @batch.Department.Name</h6>
                            <p class="card-text flex-grow-1">
                                <strong>Academic Year:</strong> @(batch.GetType().GetProperty("AcademicYear")?.GetValue(batch)?.ToString() ?? "N/A") <br/>
                                <strong>Semester:</strong> @(batch.GetType().GetProperty("Semester")?.GetValue(batch)?.ToString() ?? "N/A")
                            </p>
                            
                            <!-- THIS IS THE CRITICAL LINK -->
                            <!-- It uses real data from the model (batch.Id, batch.AcademicYear, batch.Semester) -->
                            <a asp-action="ManageOffering"
                            asp-controller="CourseManager"
                            asp-route-batchId="@batch.Id"
                            asp-route-year='@(batch.GetType().GetProperty("AcademicYear")?.GetValue(batch)?.ToString() ?? "")'
                            asp-route-semester='@(batch.GetType().GetProperty("Semester")?.GetValue(batch)?.ToString() ?? "")'
                            class="btn btn-primary mt-3 w-full">
                                Go to Management
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>