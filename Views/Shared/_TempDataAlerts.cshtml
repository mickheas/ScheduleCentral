@{
    var success = TempData["Success"] as string;
    var error = TempData["Error"] as string;

    TempData.Remove("Success");
    TempData.Remove("Error");
}

@if (!string.IsNullOrWhiteSpace(success))
{
    <div class="alert alert-success border-0 shadow-sm mb-4 d-flex align-items-center alert-dismissible fade show" style="background-color: #f0fdf4; color: #166534;">
        <i class="bi bi-check-circle-fill me-2"></i>
        <div>@success</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger border-0 shadow-sm mb-4 d-flex align-items-center alert-dismissible fade show" style="background-color: #fef2f2; color: #991b1b;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>@error</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
