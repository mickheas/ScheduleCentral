                                                            <span class="text-muted" style="font-size: 0.75rem;">@n.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                                                        </div>
                                                        @if (!string.IsNullOrWhiteSpace(n.Message))
                                                        {
