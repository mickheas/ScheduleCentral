@using System.Text.Json
@model ScheduleCentral.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Custom Styles for Dashboard Cards */
    .card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    
    /* Gradient / Accent Backgrounds for metric cards */
    .bg-gradient-primary { background: linear-gradient(45deg, #4e73df 0%, #224abe 100%); }
    .bg-gradient-success { background: linear-gradient(45deg, #1cc88a 0%, #13855c 100%); }
    .bg-gradient-info { background: linear-gradient(45deg, #36b9cc 0%, #258391 100%); }
    .bg-gradient-warning { background: linear-gradient(45deg, #f6c23e 0%, #dda20a 100%); }
    
    /* Guest Hero Section */
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 4rem 2rem;
        border-radius: 1rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }
</style>

@if (!Model.IsAuthenticated)
{
    /* --- GUEST VIEW (Marketing / Welcome) --- */
    <div class="container">
        <div class="hero-section text-center">
            <h1 class="display-4 fw-bold mb-3">Welcome to CSMS</h1>
            <p class="lead mb-4">The comprehensive platform for academic scheduling, resource management, and conflict resolution.</p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-light btn-lg px-5 fw-bold text-primary shadow-sm">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Login to Portal
                </a>
            </div>
        </div>

        <div class="row g-4 py-4 row-cols-1 row-cols-md-3">
            <div class="col">
                <div class="card h-100 border-0 shadow-sm card-hover">
                    <div class="card-body text-center p-4">
                        <div class="mb-3 text-primary">
                            <i class="bi bi-calendar-check" style="font-size: 3rem;"></i>
                        </div>
                        <h3 class="fs-4 text-dark">Automated Scheduling</h3>
                        <p class="text-muted">Generate conflict-free schedules in seconds using our advanced CSP algorithm.</p>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 border-0 shadow-sm card-hover">
                    <div class="card-body text-center p-4">
                        <div class="mb-3 text-success">
                            <i class="bi bi-building-check" style="font-size: 3rem;"></i>
                        </div>
                        <h3 class="fs-4 text-dark">Resource Management</h3>
                        <p class="text-muted">Manage classrooms, labs, and studios efficiently with real-time availability tracking.</p>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 border-0 shadow-sm card-hover">
                    <div class="card-body text-center p-4">
                        <div class="mb-3 text-info">
                            <i class="bi bi-people-fill" style="font-size: 3rem;"></i>
                        </div>
                        <h3 class="fs-4 text-dark">Role-Based Access</h3>
                        <p class="text-muted">Secure portals for Admins, Instructors, and Students to view and manage their data.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    /* --- AUTHENTICATED VIEW (Dashboard) --- */

    var roleSet = new HashSet<string>(Model.UserRoles ?? Array.Empty<string>(), StringComparer.OrdinalIgnoreCase);
    var quickActions = new[]
    {
        new { Key = "admin-users", Roles = new[] { "Admin" }, Icon = "bi-person-plus-fill", Title = "Manage Users", Desc = "Create, edit, or deactivate accounts", Controller = "Admin", Action = "ListUsers" },
        new { Key = "po-history", Roles = new[] { "ProgramOfficer" }, Icon = "bi-diagram-3", Title = "Approved Offerings", Desc = "Review approved offerings and sections", Controller = "ProgramOfficer", Action = "History" },
        new { Key = "po-schedule", Roles = new[] { "ProgramOfficer" }, Icon = "bi-calendar-check", Title = "Generate Schedule", Desc = "Open schedule generation workspace", Controller = "Schedule", Action = "Index" },
        new { Key = "instructor-availability", Roles = new[] { "Instructor" }, Icon = "bi-calendar-week-fill", Title = "My Availability", Desc = "Update teaching availability", Controller = "Instructor", Action = "Availability" },
        new { Key = "department-offerings", Roles = new[] { "Department" }, Icon = "bi-journal-bookmark", Title = "Course Offerings", Desc = "Plan offerings for upcoming terms", Controller = "CourseOffering", Action = "Index" },
        new { Key = "profile", Roles = Array.Empty<string>(), Icon = "bi-gear-fill", Title = "Profile Settings", Desc = "Update password and details", Controller = "", Action = "" }
    };

    var selectedQuickActions = quickActions
        .Where(a => a.Roles.Length == 0 || a.Roles.Any(r => roleSet.Contains(r)))
        .GroupBy(a => a.Key, StringComparer.OrdinalIgnoreCase)
        .Select(g => g.First())
        .ToList();

    var primaryRole = string.IsNullOrWhiteSpace(Model.PrimaryRole)
        ? (Model.UserRoles?.FirstOrDefault() ?? "User")
        : Model.PrimaryRole;

    string primaryRoleLabel = primaryRole switch
    {
        "Department" => "Department Dashboard",
        "TopManagement" => "Executive Overview",
        "ProgramOfficer" => "Program Officer Workspace",
        "Instructor" => "Instructor Dashboard",
        "Student" => "Student Dashboard",
        "Admin" => "Admin Control Center",
        _ => "Dashboard"
    };

    var showOfferingChart = !string.Equals(primaryRole, "Instructor", StringComparison.OrdinalIgnoreCase)
                            && !string.Equals(primaryRole, "Student", StringComparison.OrdinalIgnoreCase);

    <div class="space-y-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-semibold text-slate-900">@primaryRoleLabel</h1>
                <p class="mt-1 text-sm text-slate-500">
                    Welcome back,
                    <span class="fw-bold text-primary">@Model.UserName</span>
                </p>
            </div>

            @if (Model.UserRoles != null && Model.UserRoles.Contains("Admin") && Model.PendingApprovals > 0)
            {
                <a asp-controller="Admin" asp-action="ListUsers" class="inline-flex items-center rounded-lg bg-amber-500 px-3 py-1.5 text-xs font-medium text-white shadow-sm hover:bg-amber-600">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                    @Model.PendingApprovals Pending Users
                </a>
            }
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
            @if (string.Equals(primaryRole, "Instructor", StringComparison.OrdinalIgnoreCase))
            {
                <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-indigo-500 to-indigo-600 p-4 shadow-md shadow-indigo-200/60">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-indigo-100/80">Availability Slots</p>
                            <p class="mt-1 text-2xl font-semibold text-white">@Model.MyAvailabilitySlotsSelected</p>
                            <p class="mt-1 text-xs text-indigo-100/80">Distinct time blocks.</p>
                        </div>
                        <span class="material-icons text-white/80 text-3xl">event_available</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-emerald-500 to-emerald-600 p-4 shadow-md shadow-emerald-200/60">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-emerald-100/80">Teaching Load</p>
                            <p class="mt-1 text-2xl font-semibold text-white">@Model.MyCurrentLoad<span class="text-sm font-normal"> / @Model.MyAvailableHours</span></p>
                            <p class="mt-1 text-xs text-emerald-100/80">Planned contact hours.</p>
                        </div>
                        <span class="material-icons text-white/80 text-3xl">trending_up</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Assigned Sections</p>
                            <p class="mt-1 text-2xl font-semibold text-slate-900">@Model.MyAssignedSections</p>
                            <p class="mt-1 text-xs text-slate-500">Courses currently assigned.</p>
                        </div>
                        <span class="material-icons text-indigo-500 text-3xl">class</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-slate-500">System Meetings</p>
                            <p class="mt-1 text-2xl font-semibold text-slate-900">@Model.TotalMeetings</p>
                            <p class="mt-1 text-xs text-slate-500">Total scheduled slots.</p>
                        </div>
                        <span class="material-icons text-emerald-500 text-3xl">schedule</span>
                    </div>
                </div>
            }
            else if (string.Equals(primaryRole, "ProgramOfficer", StringComparison.OrdinalIgnoreCase))
            {
                <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-indigo-500 to-indigo-600 p-4 shadow-md shadow-indigo-200/60">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-indigo-100/80">Total Offerings</p>
                            <p class="mt-1 text-2xl font-semibold text-white">@Model.TotalOfferings</p>
                            <p class="mt-1 text-xs text-indigo-100/80">All departments & years.</p>
                        </div>
                        <span class="material-icons text-white/80 text-3xl">view_list</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-emerald-500 to-emerald-600 p-4 shadow-md shadow-emerald-200/60">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-emerald-100/80">Approved Offerings</p>
                            <p class="mt-1 text-2xl font-semibold text-white">@Model.ApprovedOfferings</p>
                            <p class="mt-1 text-xs text-emerald-100/80">Ready for scheduling.</p>
                        </div>
                        <span class="material-icons text-white/80 text-3xl">check_circle</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Sections</p>
                            <p class="mt-1 text-2xl font-semibold text-slate-900">@Model.TotalSections</p>
                            <p class="mt-1 text-xs text-slate-500">Generated sections.</p>
                        </div>
                        <span class="material-icons text-indigo-500 text-3xl">groups</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Schedule Grids</p>
                            <p class="mt-1 text-2xl font-semibold text-slate-900">@Model.TotalScheduleGrids</p>
                            <p class="mt-1 text-xs text-slate-500">Published grids.</p>
                        </div>
                        <span class="material-icons text-sky-500 text-3xl">grid_on</span>
                    </div>
                </div>
            }
            else
            {
                <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-indigo-500 to-indigo-600 p-4 shadow-md shadow-indigo-200/60">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-indigo-100/80">Users</p>
                            <p class="mt-1 text-2xl font-semibold text-white">@Model.TotalUsers</p>
                            <p class="mt-1 text-xs text-indigo-100/80">@Model.TotalInstructors instructors, @Model.TotalStudents students.</p>
                        </div>
                        <span class="material-icons text-white/80 text-3xl">people</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-emerald-500 to-emerald-600 p-4 shadow-md shadow-emerald-200/60">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-emerald-100/80">Offerings</p>
                            <p class="mt-1 text-2xl font-semibold text-white">@Model.TotalOfferings</p>
                            <p class="mt-1 text-xs text-emerald-100/80">@Model.ApprovedOfferings approved total.</p>
                        </div>
                        <span class="material-icons text-white/80 text-3xl">calendar_today</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-cyan-500 to-cyan-600 p-4 shadow-md shadow-cyan-200/60">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-cyan-100/80">Departments</p>
                            <p class="mt-1 text-2xl font-semibold text-white">@Model.TotalDepartments</p>
                            <p class="mt-1 text-xs text-cyan-100/80">@Model.TotalCourses courses cataloged.</p>
                        </div>
                        <span class="material-icons text-white/80 text-3xl">school</span>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-amber-500 to-amber-600 p-4 shadow-md shadow-amber-200/60">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-xs font-medium uppercase tracking-wide text-amber-100/80">Pending</p>
                            <p class="mt-1 text-2xl font-semibold text-white">@Model.PendingApprovals</p>
                            <p class="mt-1 text-xs text-amber-100/80">Accounts awaiting activation.</p>
                        </div>
                        <span class="material-icons text-white/80 text-3xl">person_add_alt</span>
                    </div>
                </div>
            }
        </div>

        <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
            <div class="space-y-6 xl:col-span-2">
                <div class="rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
                    <div class="flex items-center justify-between border-b border-slate-100 px-5 py-3">
                        <h2 class="flex items-center text-sm font-semibold text-slate-800">
                            <span class="material-icons mr-2 text-base text-indigo-500">flash_on</span>
                            Quick Actions
                        </h2>
                    </div>
                    <div class="px-5 py-4">
                        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                            @foreach (var a in selectedQuickActions)
                            {
                                if (string.IsNullOrWhiteSpace(a.Controller))
                                {
                                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="group flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 px-3 py-3 text-sm hover:border-indigo-200 hover:bg-indigo-50">
                                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-indigo-500/10 text-indigo-600">
                                            <i class="bi @a.Icon"></i>
                                        </span>
                                        <span>
                                            <span class="block font-medium text-slate-800">@a.Title</span>
                                            <span class="block text-xs text-slate-500">@a.Desc</span>
                                        </span>
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="@a.Controller" asp-action="@a.Action" class="group flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 px-3 py-3 text-sm hover:border-indigo-200 hover:bg-indigo-50">
                                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-indigo-500/10 text-indigo-600">
                                            <i class="bi @a.Icon"></i>
                                        </span>
                                        <span>
                                            <span class="block font-medium text-slate-800">@a.Title</span>
                                            <span class="block text-xs text-slate-500">@a.Desc</span>
                                        </span>
                                    </a>
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
                    <div class="flex items-center justify-between border-b border-slate-100 px-5 py-3">
                        <h2 class="flex items-center text-sm font-semibold text-slate-800">
                            <span class="material-icons mr-2 text-base text-sky-500">notifications</span>
                            Recent Activity
                        </h2>
                        @if (Model.UnreadNotifications > 0)
                        {
                            <a asp-controller="Notifications" asp-action="Index" class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-medium text-amber-700">
                                @Model.UnreadNotifications unread
                            </a>
                        }
                    </div>
                    <div class="px-5 py-4">
                        @if (Model.RecentNotifications == null || Model.RecentNotifications.Count == 0)
                        {
                            <p class="text-xs text-slate-500">No recent notifications.</p>
                        }
                        else
                        {
                            <div class="space-y-2">
                                @foreach (var n in Model.RecentNotifications)
                                {
                                    <a asp-controller="Notifications" asp-action="Go" asp-route-id="@n.Id"
                                       class="block rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 hover:border-indigo-200 hover:bg-indigo-50">
                                        <div class="flex items-start justify-between gap-3">
                                            <div>
                                                <div class="text-sm font-medium text-slate-800">@n.Title</div>
                                                @if (!string.IsNullOrWhiteSpace(n.Message))
                                                {
                                                    <div class="text-xs text-slate-500">@n.Message</div>
                                                }
                                                <div class="text-[11px] text-slate-400 mt-1">@n.CreatedAtUtc.ToLocalTime().ToString("g")</div>
                                            </div>
                                            @if (!n.IsRead)
                                            {
                                                <span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-amber-500"></span>
                                            }
                                        </div>
                                    </a>
                                }
                            </div>

                            <div class="mt-3">
                                <a asp-controller="Notifications" asp-action="Index" class="text-xs font-medium text-indigo-600 hover:text-indigo-700">View all notifications</a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                @if (showOfferingChart)
                {
                    <div class="rounded-2xl bg-white shadow-sm ring-1 ring-slate-200" id="offeringsStatusCard">
                        <div class="flex items-center justify-between border-b border-slate-100 px-5 py-3">
                            <h2 class="flex items-center text-sm font-semibold text-slate-800">
                                <span class="material-icons mr-2 text-base text-emerald-500">pie_chart</span>
                                Offering Distribution
                            </h2>
                        </div>
                        <div class="p-5">
                            <div class="h-72">
                                <canvas id="offeringsStatusChart"></canvas>
                            </div>
                            @if (Model.OfferingsByStatus == null || !Model.OfferingsByStatus.Any())
                            {
                                <p class="mt-3 text-xs text-slate-500">No offerings found yet for analytics.</p>
                            }
                        </div>
                    </div>
                }

                <div class="rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
                    <div class="flex items-center justify-between border-b border-slate-100 px-5 py-3">
                        <h2 class="flex items-center text-sm font-semibold text-slate-800">
                            <span class="material-icons mr-2 text-base text-emerald-500">health_and_safety</span>
                            System Status
                        </h2>
                        <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700">Operational</span>
                    </div>
                    <div class="px-5 py-4">
                        <ul class="space-y-2 text-xs text-slate-600">
                            <li class="flex items-center gap-2">
                                <i class="bi bi-check-circle-fill text-emerald-500"></i>
                                <span>@Model.TotalScheduleGrids schedule grids created.</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="bi bi-clock-history text-indigo-500"></i>
                                <span>@Model.TotalMeetings scheduled meeting slots.</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="bi bi-diagram-3-fill text-sky-500"></i>
                                <span>@Model.TotalSections sections currently tracked.</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var canvas = document.getElementById('offeringsStatusChart');
            if (!canvas) return;

            var rawData = @Html.Raw(JsonSerializer.Serialize(Model.OfferingsByStatus ?? new Dictionary<string, int>()));
            var labels = Object.keys(rawData);
            var values = Object.values(rawData);

            if (labels.length === 0) {
                return;
            }

            var statusPalette = {
                "Draft": "#9ca3af",
                "Submitted": "#0ea5e9",
                "InReview": "#6366f1",
                "Approved": "#22c55e",
                "Rejected": "#ef4444",
                "Returned": "#f97316"
            };

            var fallbackColors = [
                "#4f46e5", "#0ea5e9", "#22c55e", "#f97316", "#ec4899", "#6366f1"
            ];

            // Helper to add opacity to hex colors for Polar Area style
            function hexToRgba(hex, alpha) {
                if(!hex) return 'rgba(0,0,0,0.5)';
                var r = parseInt(hex.slice(1, 3), 16),
                    g = parseInt(hex.slice(3, 5), 16),
                    b = parseInt(hex.slice(5, 7), 16);
                return `rgba(${r}, ${g}, ${b}, ${alpha})`;
            }

            var backgroundColors = labels.map(function (label, index) {
                var hex = statusPalette[label] || fallbackColors[index % fallbackColors.length];
                return hexToRgba(hex, 0.6); // 60% opacity for filling
            });

            var borderColors = labels.map(function (label, index) {
                var hex = statusPalette[label] || fallbackColors[index % fallbackColors.length];
                return hex; // Solid color for border
            });

            var ctx = canvas.getContext('2d');
            new Chart(ctx, {
                type: 'polarArea',
                data: {
                    labels: labels,
                    datasets: [{
                        data: values,
                        backgroundColor: backgroundColors,
                        borderColor: borderColors,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            ticks: {
                                display: false, // Hide the concentric numbers
                                backdropColor: 'transparent' 
                            },
                            grid: {
                                color: '#e2e8f0' // Subtle Slate-200 grid
                            },
                            pointLabels: {
                                display: true,
                                centerPointLabels: true,
                                font: {
                                    size: 11
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 20,
                                font: {
                                    size: 11
                                }
                            }
                        },
                        tooltip: {
                            backgroundColor: '#0f172a',
                            padding: 12,
                            titleFont: { size: 13 },
                            bodyFont: { size: 12 },
                            cornerRadius: 8,
                            displayColors: true
                        }
                    },
                    layout: {
                        padding: 10
                    }
                }
            });
        });
    </script>
}