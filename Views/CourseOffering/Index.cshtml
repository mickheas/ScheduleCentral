@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="d-flex justify-content-between mb-3">
    <h2 class="h4">Course Offerings</h2>

    <a class="btn btn-primary" asp-action="Create" role="button">
        <i class="bi bi-plus-circle"></i> Create Offering
    </a>
</div>

<div class="row">
   
    @if (Model.CourseOfferings == null || !Model.CourseOfferings.Any())
    {
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4 text-center text-muted">
                <p class="mb-0">No course offerings yet. Click <strong>Create Offering</strong> to start one.</p>
            </div>
        </div>
    }
    else
    {
       
        foreach (var item in Model.CourseOfferings)
