@model ScheduleCentral.Models.ViewModels.CourseOfferingIndexViewModel
@{
    ViewData["Title"] = "Course Offering Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0">Course Offering Details</h5>
            <small class="text-muted">Read-only view</small>
        </div>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Back</a>
        </div>
    </div>

    <div class="accordion" id="detailsYearAccordion">
        @* Reuse YearProgramViewModel structure; just render text *@
        @foreach (var year in Model.YearPrograms)
        {
        <div class="accordion-item mb-2">
            <h2 class="accordion-header" id="dheading-@year.Id">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#dcollapse-@year.Id">
                @((year.YearLevel == "1") ? "1st Year" : (year.YearLevel == "2" ? "2nd Year" : year.YearLevel + "th Year")) – @year.ProgramType
            </button>
            </h2>

            <div id="dcollapse-@year.Id" class="accordion-collapse collapse" data-bs-parent="#detailsYearAccordion">
            <div class="accordion-body">
                @foreach (var batch in year.Batches)
                {
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@batch.BatchName</strong>
                        <div class="small text-muted">@batch.SemesterName</div>
                    </div>
                    </div>
                    <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-borderless table-sm">
                        <thead>
                            <tr class="text-muted small">
                            <th>#</th>
                            <th>Course</th>
                            <th>Contact Hrs</th>
                            <th>Room Types</th>
                            <th>Instructor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (batch.Courses.Any())
                            {
                            var idx = 1;
                            foreach (var c in batch.Courses)
                            {
                                <tr>
                                <td>@(idx++)</td>
                                <td>@c.CourseName</td>
                                <td>@c.ContactHours</td>
                                <td>@string.Join(", ", c.RoomTypes)</td>
                                <td>@c.InstructorName</td>
                                </tr>
                            }
                            }
                            else
                            {
                            <tr>
                                <td colspan="5" class="text-muted">No courses added yet.</td>
                            </tr>
                            }
                        </tbody>
                        </table>
                    </div>
                    </div>
                </div>
                }
            </div>
            </div>
        </div>
        }
    </div>
</div>
