@model ScheduleCentral.Models.ViewModels.CourseOfferingDeleteViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Delete Course Offering";
}

<div class="container mt-4">
    <div class="card shadow-sm border-danger">
        <div class="card-body">
            <h5 class="text-danger">Confirm Delete</h5>
            <p>Are you sure you want to delete the offering: <strong>@Model.CourseName</strong> ?</p>

            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
